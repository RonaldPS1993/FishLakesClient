{
  "expo": {
    "name": "FishLakes",
    "slug": "FishLakes",
    "scheme": "fishlakes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/fishlakes.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ronaldpenasollet.FishLakes",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ronaldpenasollet.FishLakes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/fishlakes.png",
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/icons/fishlakes.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow FishLakes to use your location."
        }
      ],
      "expo-font",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.216478643881-ah9joinuchar60ok4nb8at48hc5bl6j2"
        }
      ],
      "expo-web-browser"
    ],
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "9fb2ec6f-eab5-4256-a781-40191e6b2e91"
      }
    }
  }
}
